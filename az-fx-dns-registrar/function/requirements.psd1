# Managed dependencies pulled automatically by the Functions host
# (requires "managedDependency": { "enabled": true } in host.json).
# Pin to major versions to avoid surprise breaking changes.
@{
    'Az.Accounts'      = '3.*'
    'Az.Compute'       = '8.*'
    'Az.Network'       = '7.*'
    'Az.PrivateDns'    = '1.*'
    'Az.ResourceGraph' = '1.*'
}
