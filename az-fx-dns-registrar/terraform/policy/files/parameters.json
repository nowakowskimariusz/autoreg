{
  "effect": {
    "type": "String",
    "metadata": {
      "displayName": "Effect",
      "description": "Enable or disable execution of the policy."
    },
    "allowedValues": [
      "DeployIfNotExists",
      "AuditIfNotExists",
      "Disabled"
    ],
    "defaultValue": "DeployIfNotExists"
  },
  "registrarFunctionId": {
    "type": "String",
    "metadata": {
      "displayName": "Registrar function ID",
      "description": "Resource ID of the central RegisterVmDns function (.../functions/RegisterVmDns)."
    }
  },
  "resourceGroupName": {
    "type": "String",
    "metadata": {
      "displayName": "Resource group name",
      "description": "EXISTING resource group in each spoke that will hold the Event Grid system topic (workload subscriptions already have rg-network)."
    },
    "defaultValue": "rg-network"
  },
  "systemTopicName": {
    "type": "String",
    "metadata": {
      "displayName": "System topic name",
      "description": "Name of the shared subscription-level Event Grid system topic."
    },
    "defaultValue": "egst-subscription-events"
  },
  "deploymentLocation": {
    "type": "String",
    "metadata": {
      "displayName": "Deployment location",
      "description": "Region used for the subscription deployment metadata."
    },
    "defaultValue": "westeurope"
  }
}
